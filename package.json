{
  "name": "doc-editor",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000 --host 0.0.0.0",
    "dev:docker": "pnpm run generate && pnpm run db:push && vite dev --port 3000 --host 0.0.0.0 --strictPort",
    "build": "pnpm run generate && vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production pnpm run build && pnpm run preview",
    "test": "vitest run --config vitest.config.ts",
    "coverage": "vitest run --config vitest.config.ts --coverage",
    "ts": "pnpm exec tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "scan": "npx fallow",
    "generate": "pnpm prisma generate && npx tsx scripts/sync-meta.ts",
    "db:push": "tsx --env-file=.env ./scripts/push-schema.ts",
    "seed": "tsx --env-file=.env ./prisma/seeders/index.ts",
    "migrate:addresses": "tsx --env-file=.env ./scripts/migrate-address-data.ts",
    "reset": "tsx --env-file=.env ./scripts/reset-db.ts",
    "docker:dev": "docker compose up --build --watch",
    "docker:down": "docker compose down",
    "docker:exec": "docker compose exec -it app-fe"
  },
  "prisma": {
    "seed": "tsx --env-file=.env ./prisma/seeders/index.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.3.2",
    "@serwist/window": "^9.5.7",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/browser-db-sqlite-persistence": "^0.1.9",
    "@tanstack/db": "0.6.5",
    "@tanstack/query-db-collection": "^1.0.31",
    "@tanstack/react-db": "^0.1.78",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-store": "^0.9.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "@tiptap/extension-character-count": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-underline": "^3.28.0",

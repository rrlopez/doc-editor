    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.20",
    "lodash": "^4.18.1",
    "lucide-react": "^0.564.0",
    "neverthrow": "^8.2.0",
    "next-themes": "^0.4.6",
    "numeral": "^2.0.6",
    "papaparse": "^5.5.3",
    "pg": "8.18.0",
    "print-js-updated": "^1.6.1",

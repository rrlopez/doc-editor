# --- App ---
HOST=0.0.0.0
PORT=3000
PUBLIC_PORT=3200
NODE_ENV=development

# CANONICAL_URL and BETTER_AUTH_URL must match the URL your browser hits.
# Local dev (pnpm run dev, no Docker):  use PORT → http://localhost:3000
# Docker Compose:                        use PUBLIC_PORT → http://localhost:3200
CANONICAL_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_INTERNAL_URL=http://127.0.0.1:3000
BETTER_AUTH_SECRET=change-me

LOCAL_DB_NAME=my_app_storage

# --- Database ---
# Local development (running outside Docker): use localhost
# Docker Compose (running inside Docker): use db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=doc-editor

# Optional non-interactive seed/reset:
# SEED_AUTO_CONFIRM=yes
# SEED_FOLDER=examples
# RESET_AUTO_CONFIRM=yes

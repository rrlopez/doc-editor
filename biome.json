{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "files": {
    "includes": [
      "**",
      "!!node_modules",
      "!!.output",
      "!!dist",
      "!prisma/generated",
      "!src/components/ui",
      "!!public",
      "!!coverage",
      "!!test-results",
      "!!cspell.json",
      "!!src/routeTree.gen.ts"
    ]
  },
  "javascript": {
    "jsxRuntime": "transparent",
    "formatter": {
      "lineWidth": 160,
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "semicolons": "asNeeded",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "quoteProperties": "asNeeded",
      "attributePosition": "auto"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": { "noUnusedImports": "error", "useExhaustiveDependencies": "warn", "useHookAtTopLevel": "error", "noChildrenProp": "off" },
      "complexity": {
        "useLiteralKeys": "off"
      },
      "style": {
        "useImportType": "error",
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 160,
    "attributePosition": "auto",
    "lineEnding": "lf"
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "identifierOrder": "natural"
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/styles.css"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    }
  ]
}
